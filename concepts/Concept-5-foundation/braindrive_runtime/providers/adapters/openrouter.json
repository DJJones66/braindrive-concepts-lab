{
  "provider": "openrouter",
  "adapter_factory": "braindrive_runtime.providers.openrouter:OpenRouterAdapter",
  "adapter_kwargs": {
    "base_url": {
      "env": "BRAINDRIVE_OPENROUTER_BASE_URL",
      "default": "https://openrouter.ai/api/v1"
    },
    "api_key": {
      "env": "BRAINDRIVE_OPENROUTER_API_KEY",
      "default": ""
    },
    "site_url": {
      "env": "BRAINDRIVE_OPENROUTER_SITE_URL",
      "default": ""
    },
    "app_name": {
      "env": "BRAINDRIVE_OPENROUTER_APP_NAME",
      "default": "BrainDrive-MVP"
    },
    "timeout_sec": {
      "env": "BRAINDRIVE_MODEL_TIMEOUT_SEC",
      "default": "30"
    }
  },
  "model_node": {
    "node_id": "node.model.openrouter",
    "priority": 170,
    "label": "OpenRouter"
  },
  "config": {
    "base_url_env": "BRAINDRIVE_OPENROUTER_BASE_URL",
    "base_url_default": "https://openrouter.ai/api/v1",
    "base_url_required": false,
    "default_model_env": "BRAINDRIVE_OPENROUTER_DEFAULT_MODEL",
    "required_env": [
      "BRAINDRIVE_OPENROUTER_API_KEY"
    ],
    "required_env_messages": {
      "BRAINDRIVE_OPENROUTER_API_KEY": "BRAINDRIVE_OPENROUTER_API_KEY is required for provider openrouter"
    },
    "startup_notice": "requires BRAINDRIVE_OPENROUTER_API_KEY"
  }
}
