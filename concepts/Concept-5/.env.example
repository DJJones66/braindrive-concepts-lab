# Host ports
BRAINDRIVE_ROUTER_PORT=9480
BRAINDRIVE_INTENT_PORT=9481
BRAINDRIVE_WEBCONSOLE_PORT=9493
BRAINDRIVE_DEV_WEBTERM_BIND_ADDR=0.0.0.0
BRAINDRIVE_DEV_WEBTERM_PORT=9494
INTENT_ROUTER_CATALOG_TIMEOUT_SEC=5
INTENT_ROUTER_ROUTE_TIMEOUT_SEC=240

# Shared registration token
ROUTER_REGISTRATION_TOKEN=braindrive-mvp-dev-token
ROUTER_NODE_TIMEOUT_SEC=180
ROUTER_DIRECT_ROUTE_TIMEOUT_SEC=180
# Defaults for container process user.
# scripts/bootstrap.sh injects HOST_UID/HOST_GID from your current shell at startup.
HOST_UID=1001
HOST_GID=1001

BRAINDRIVE_DEFAULT_PROVIDER=openrouter
BRAINDRIVE_OPENROUTER_API_KEY=
BRAINDRIVE_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
BRAINDRIVE_OPENROUTER_DEFAULT_MODEL=minimax/minimax-m2.5
BRAINDRIVE_OPENROUTER_SITE_URL=
BRAINDRIVE_OPENROUTER_APP_NAME=BrainDrive-MVP
BRAINDRIVE_OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
BRAINDRIVE_OLLAMA_API_KEY=
BRAINDRIVE_OLLAMA_DEFAULT_MODEL=llama3:8b
BRAINDRIVE_MODEL_TIMEOUT_SEC=180
BRAINDRIVE_ENABLE_TEST_ENDPOINTS=false
# Full intent-route trace records in data/runtime/logs/workflow.jsonl
# true: log request + analysis + route_message + route_response
# false: keep workflow log to workflow-domain events only
BRAINDRIVE_WORKFLOW_FULL_TRACE=true

# CLI colors (name-based theme controls)
# valid values: black, red, green, yellow, blue, magenta, cyan, white,
#               bright_black, bright_red, bright_green, bright_yellow,
#               bright_blue, bright_magenta, bright_cyan, bright_white
BRAINDRIVE_CLI_COLOR=auto
BRAINDRIVE_CLI_COLOR_SYSTEM=cyan
BRAINDRIVE_CLI_COLOR_AI=green
# legacy fallback used when prompt-specific colors are unset
BRAINDRIVE_CLI_COLOR_USER=magenta
BRAINDRIVE_CLI_COLOR_PROMPT_APP=blue
BRAINDRIVE_CLI_COLOR_PROMPT_FOLDER=green
BRAINDRIVE_CLI_COLOR_PROMPT_ARROW=blue
BRAINDRIVE_CLI_COLOR_BANNER=blue
BRAINDRIVE_CLI_COLOR_VERSION=red

# Real token streaming for model chat output in CLI
BRAINDRIVE_CLI_TIMEOUT_SEC=300
BRAINDRIVE_CLI_STREAM_MODEL_CHAT=true
# true: stream only fallback chat + explicit model stream requests
# false: stream all model.chat.* responses
BRAINDRIVE_CLI_STREAM_FALLBACK_ONLY=true
# print stream diagnostics after each streamed reply (ttft/chunks/total)
BRAINDRIVE_CLI_STREAM_DIAGNOSTICS=false

# Scrapling web scraping node
BRAINDRIVE_SCRAPLING_ENABLED=true
BRAINDRIVE_SCRAPLING_ALLOW_PRIVATE_NET=false
BRAINDRIVE_SCRAPLING_ALLOWED_DOMAINS=
BRAINDRIVE_SCRAPLING_BLOCKED_DOMAINS=
BRAINDRIVE_SCRAPLING_MAX_URLS=10
BRAINDRIVE_SCRAPLING_MAX_CONTENT_CHARS=120000
BRAINDRIVE_SCRAPLING_TIMEOUT_SEC=30
BRAINDRIVE_SCRAPLING_BROWSER_TIMEOUT_MS=30000
BRAINDRIVE_SCRAPLING_STEALTH_ENABLED=true
BRAINDRIVE_SCRAPLING_DEFAULT_SAVE=true
BRAINDRIVE_SCRAPLING_DEFAULT_SAVE_DIR=scraping

# Web terminal console node
WEBTERM_ENABLED=true
WEBTERM_ALLOWED_ORIGINS=https://localhost:8443,https://127.0.0.1:8443
WEBTERM_SESSION_IDLE_TIMEOUT_SEC=900
WEBTERM_SESSION_MAX_TIMEOUT_SEC=3600
WEBTERM_MAX_CONCURRENT_SESSIONS_PER_USER=2
WEBTERM_MAX_MESSAGE_BYTES=4096
WEBTERM_MAX_EVENTS_PER_MINUTE=120
WEBTERM_TARGETS=node-router,node-memory-fs,node-workflow-folder,node-workflow-skill,node-chat-general
WEBTERM_SSH_GATEWAY_HOST=ssh-gateway
WEBTERM_SSH_GATEWAY_PORT=2226
WEBTERM_SSH_TARGET_DEFAULT=node-router
WEBTERM_SSH_AUTH_MODE=disabled
WEBTERM_SSH_CA_KEY_FILE=
WEBTERM_SSH_CLIENT_KEY_FILE=
WEBTERM_SSH_CLIENT_PUB_FILE=
WEBTERM_SSH_KNOWN_HOSTS_FILE=
WEBTERM_SSH_AUTHORIZED_KEYS_FILE=
WEBTERM_SSH_CLIENT_KEY_B64=
WEBTERM_SSH_CLIENT_PUB_B64=
WEBTERM_SSH_AUTHORIZED_KEYS_B64=
WEBTERM_SSH_EXEC_INTENT=
WEBTERM_INTENT_ROUTER_BASE_URL=http://intent-router-natural-language:8081
WEBTERM_ROUTER_BASE_URL=http://node-router:8080
WEBTERM_HTTP_TIMEOUT_SEC=60

# Dev-only raw web terminal (separate from protocol web console)
DEV_WEBTERM_AUTH_USER=dev
DEV_WEBTERM_AUTH_PASSWORD=change-me-now
DEV_WEBTERM_LOG_LEVEL=2
DEV_WEBTERM_THEME_BACKGROUND=#000000
