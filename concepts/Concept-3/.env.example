# Host ports
CONCEPT3_ROUTER_PORT=9380
CONCEPT3_INTENT_PORT=9381
INTENT_ROUTER_CATALOG_TIMEOUT_SEC=2
INTENT_ROUTER_ROUTE_TIMEOUT_SEC=60

# Shared registration token
ROUTER_REGISTRATION_TOKEN=concept3-dev-token
ROUTER_NODE_TIMEOUT_SEC=45
HOST_UID=1001
HOST_GID=1001

BRAINDRIVE_DEFAULT_PROVIDER=openrouter
BRAINDRIVE_OPENROUTER_API_KEY=
BRAINDRIVE_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
BRAINDRIVE_OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4
BRAINDRIVE_OPENROUTER_SITE_URL=
BRAINDRIVE_OPENROUTER_APP_NAME=BrainDrive Concept-3
BRAINDRIVE_OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
BRAINDRIVE_OLLAMA_API_KEY=
BRAINDRIVE_OLLAMA_DEFAULT_MODEL=llama3:8b
BRAINDRIVE_MODEL_TIMEOUT_SEC=30
BRAINDRIVE_ENABLE_TEST_ENDPOINTS=false
